#!/bin/sh
# Maven wrapper script - automatically downloads Maven if not present

MAVEN_HOME="${HOME}/.m2/wrapper"
MAVEN_VERSION="3.9.6"
MAVEN_URL="https://archive.apache.org/dist/maven/maven-3/${MAVEN_VERSION}/binaries/apache-maven-${MAVEN_VERSION}-bin.zip"

# Create .m2/wrapper directory if it doesn't exist
mkdir -p "${MAVEN_HOME}"

# Check if Maven is already downloaded
if [ ! -d "${MAVEN_HOME}/apache-maven-${MAVEN_VERSION}" ]; then
    echo "Downloading Maven ${MAVEN_VERSION}..."
    
    # Download Maven
    if ! curl -fsSL "${MAVEN_URL}" -o "${MAVEN_HOME}/maven.zip"; then
        echo "Failed to download Maven. Please install it manually from https://maven.apache.org/download.cgi"
        exit 1
    fi
    
    # Extract Maven
    echo "Extracting Maven..."
    cd "${MAVEN_HOME}"
    unzip -q maven.zip
    rm maven.zip
    echo "Maven installed successfully!"
fi

# Set up Maven home and run
export MAVEN_HOME="${MAVEN_HOME}/apache-maven-${MAVEN_VERSION}"
export PATH="${MAVEN_HOME}/bin:${PATH}"

# Run Maven with passed arguments
exec "${MAVEN_HOME}/bin/mvn" "$@"
